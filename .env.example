# Public Sepolia RPC endpoint
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_KEY

# Private key that pays gas for deployment
DEPLOYER_PRIVATE_KEY=0xYOUR_DEPLOYER_PRIVATE_KEY

# Private key used by the gateway to sign EIP-712 resolver responses
SIGNER_PRIVATE_KEY=0xYOUR_SIGNER_PRIVATE_KEY

# Optional: explicit allowed signer address if you do not want deploy.ts to derive it from the private key
# ALLOWED_SIGNER_ADDRESS=0xYourSignerAddress

# Public HTTPS endpoint that will host POST /resolve
GATEWAY_URL=https://your-domain.example/resolve

# Fill this in after deployment
RESOLVER_ADDRESS=0xYourDeployedResolverAddress

# ENS name you control on Sepolia and want to point at the resolver
TARGET_ENS_NAME=yourname.eth

# Optional: private key that controls the ENS name; falls back to DEPLOYER_PRIVATE_KEY
# NAME_MANAGER_PRIVATE_KEY=0xYourNameManagerPrivateKey

# Optional: override official Sepolia ENS deployments if needed
# ENS_REGISTRY_ADDRESS=0x00000000000C2E074eC69A0dFb2997BA6C7d2e1e
# NAME_WRAPPER_ADDRESS=0x0635513f179D50A207757E05759CbD106d7dFcE8

# Required for Etherscan verification
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_API_KEY

# Expected signing domain chain ID for Sepolia
CHAIN_ID=11155111

# Optional gateway port for local hosting
PORT=3000

# Optional proof inputs
ENS_NAME=alice.eth
TEXT_KEY=url
TEXT_VALUE=https://resolver.demo/alice.eth/url
