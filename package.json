{
  "name": "signed-offchain-data-starter-kit",
  "version": "1.0.0",
  "private": true,
  "description": "Starter kit for signed offchain reads using EIP-3668 and EIP-712, with ENS and config-reader examples",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "build": "forge build",
    "typecheck": "tsc --noEmit",
    "test": "forge test -vv",
    "deploy": "tsx scripts/deploy.ts",
    "deploy:sepolia": "tsx scripts/deploy.ts",
    "demo:config": "tsx scripts/demo-config.ts",
    "check-name:sepolia": "tsx scripts/check-name.ts",
    "set-resolver:sepolia": "tsx scripts/set-resolver.ts",
    "verify:sepolia": "tsx scripts/verify.ts",
    "prove:sepolia": "tsx scripts/prove-live.ts",
    "sign": "tsx scripts/sign.ts",
    "gateway": "tsx gateway/server.ts",
    "demo": "tsx scripts/demo.ts",
    "check": "npm run typecheck && npm run build && npm run test"
  },
  "keywords": [
    "ccip-read",
    "eip-3668",
    "eip-712",
    "ethereum",
    "ens",
    "offchain-data",
    "solidity",
    "typescript"
  ],
  "license": "MIT",
  "type": "module",
  "overrides": {
    "path-to-regexp": "8.4.2"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.6.1",
    "dotenv": "^17.3.1",
    "ethers": "^6.16.0",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
